@page "/events"
@using ShatteredRealms.Application.DTOs.Events
@using ShatteredRealms.Application.DTOs.Announcements
@using ShatteredRealms.Web.Services
@inject EventClientService EventService
@inject AnnouncementClientService AnnouncementService
@inject AuthService AuthService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Events — ShatteredRealms</PageTitle>

<div class="events-page">
    <div class="events-header">
        <div>
            <h1 class="events-title">Events</h1>
            <p class="events-subtitle">Upcoming community gatherings and activities</p>
        </div>
        @if (_canCreate)
        {
            <button class="btn-gold-outline" @onclick="ShowCreateModal">+ Create Event</button>
        }
    </div>

    @if (!string.IsNullOrEmpty(_error))
    {
        <div class="alert alert-danger">@_error</div>
    }

    @if (_loading)
    {
        <div class="events-loading">
            <div class="loading-orb"></div>
            <span>Loading events…</span>
        </div>
    }
    else if (_events.Count == 0)
    {
        <div class="events-empty">
            <p>No upcoming events. Check back soon.</p>
        </div>
    }
    else
    {
        <div class="events-grid">
            @foreach (var ev in _events)
            {
                <div class="event-card" @onclick="() => GoToEvent(ev.Id)">
                    @if (!string.IsNullOrEmpty(ev.BannerImagePath))
                    {
                        <div class="event-banner" style="background-image: url('@EventService.GetBannerUrl(ev.BannerImagePath)')"></div>
                    }
                    else
                    {
                        <div class="event-banner event-banner--placeholder"></div>
                    }
                    <div class="event-card-body">
                        <div class="event-date">
                            <span class="event-date-day">@ev.StartsAt.ToString("dd")</span>
                            <span class="event-date-month">@ev.StartsAt.ToString("MMM").ToUpper()</span>
                        </div>
                        <div class="event-info">
                            <h3 class="event-name">@ev.Title</h3>
                            @if (!string.IsNullOrEmpty(ev.Location))
                            {
                                <p class="event-location">📍 @ev.Location</p>
                            }
                            <div class="event-meta">
                                <span class="event-time">@ev.StartsAt.ToString("HH:mm") – @ev.EndsAt.ToString("HH:mm")</span>
                                <span class="event-attendees">
                                    @ev.AttendeeCount @(ev.MemberCap.HasValue ? $"/ {ev.MemberCap}" : "") going
                                </span>
                            </div>
                        </div>
                        @if (ev.IsGoing)
                        {
                            <div class="event-going-badge">Going ✓</div>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

@if (_showCreateModal)
{
    <div class="modal-backdrop" @onclick="CloseModal">
        <div class="modal-panel" @onclick:stopPropagation>
            <div class="modal-header">
                <h2>Create Event</h2>
                <button class="modal-close" @onclick="CloseModal">×</button>
            </div>
            <div class="modal-body">
                @if (!string.IsNullOrEmpty(_formError))
                {
                    <div class="alert alert-danger">@_formError</div>
                }
                <div class="form-group">
                    <label class="form-label">Title</label>
                    <input class="form-control" @bind="_form.Title" placeholder="Event title" />
                </div>
                <div class="form-group">
                    <label class="form-label">Description</label>
                    <textarea class="form-control" rows="4" @bind="_form.Description" placeholder="What's happening?"></textarea>
                </div>
                <div class="form-grid">
                    <div class="form-group">
                        <label class="form-label">Start</label>
                        <input class="form-control" type="datetime-local" @bind="_form.StartsAt" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">End</label>
                        <input class="form-control" type="datetime-local" @bind="_form.EndsAt" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Location (optional)</label>
                        <input class="form-control" @bind="_form.Location" placeholder="Place or URL" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Capacity cap (optional)</label>
                        <input class="form-control" type="number" @bind="_form.MemberCap" min="1" placeholder="Unlimited" />
                    </div>
                </div>

                <div class="announcement-toggle">
                    <label class="checkbox-label">
                        <input type="checkbox" @bind="_createAnnouncement" />
                        <span>Also create a linked announcement</span>
                    </label>
                </div>

                @if (_createAnnouncement)
                {
                    <div class="announcement-fields">
                        <div class="form-group">
                            <label class="form-label">Announcement Title</label>
                            <input class="form-control" @bind="_annForm.Title" placeholder="e.g. New Event: Summer Raid Night" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Announcement Body</label>
                            <textarea class="form-control" rows="3" @bind="_annForm.Body" placeholder="Write a short announcement for this event…"></textarea>
                        </div>
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn-secondary" @onclick="CloseModal">Cancel</button>
                <button class="btn-gold" @onclick="CreateEvent" disabled="@_saving">
                    @(_saving ? "Creating…" : "Create Event")
                </button>
            </div>
        </div>
    </div>
}

<style>
    .events-page { max-width: 1000px; margin: 0 auto; padding: 2rem 1rem 4rem; }

    .events-header {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        margin-bottom: 2rem;
        flex-wrap: wrap;
        gap: 1rem;
    }
    .events-title {
        font-family: var(--font-heading);
        font-size: 2rem;
        color: var(--gold);
        margin: 0 0 0.25rem;
    }
    .events-subtitle { font-family: var(--font-body); color: var(--text-muted); margin: 0; font-size: 0.95rem; }

    .btn-gold-outline {
        padding: 0.55rem 1.3rem;
        border: 1px solid var(--gold);
        background: transparent;
        color: var(--gold);
        border-radius: 6px;
        font-family: var(--font-heading);
        font-size: 0.82rem;
        font-weight: 700;
        letter-spacing: 0.06em;
        cursor: pointer;
        transition: background 0.15s, color 0.15s;
    }
    .btn-gold-outline:hover { background: var(--gold); color: #07090f; }

    .events-loading {
        display: flex; align-items: center; gap: 1rem;
        justify-content: center; padding: 4rem;
        color: var(--text-muted); font-family: var(--font-body);
    }
    .loading-orb {
        width: 22px; height: 22px;
        border: 2px solid rgba(201,168,76,0.2);
        border-top-color: var(--gold);
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
    }
    @@keyframes spin { to { transform: rotate(360deg); } }

    .events-empty {
        text-align: center; padding: 4rem;
        color: var(--text-muted); font-family: var(--font-body);
    }

    .events-grid { display: flex; flex-direction: column; gap: 1rem; }

    .event-card {
        display: flex;
        flex-direction: column;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 10px;
        overflow: hidden;
        cursor: pointer;
        transition: border-color 0.15s, transform 0.1s;
    }
    .event-card:hover { border-color: rgba(201,168,76,0.4); transform: translateY(-1px); }

    .event-banner {
        height: 160px;
        background-size: cover;
        background-position: center;
    }
    .event-banner--placeholder {
        background: linear-gradient(135deg, #12161e, #0d1219);
    }

    .event-card-body {
        display: flex;
        align-items: center;
        gap: 1.25rem;
        padding: 1.25rem 1.5rem;
        position: relative;
    }
    .event-date {
        display: flex; flex-direction: column; align-items: center;
        min-width: 48px;
        background: rgba(201,168,76,0.08);
        border: 1px solid rgba(201,168,76,0.2);
        border-radius: 8px;
        padding: 0.5rem;
    }
    .event-date-day { font-family: var(--font-heading); font-size: 1.5rem; color: var(--gold); line-height: 1; }
    .event-date-month { font-family: var(--font-body); font-size: 0.7rem; color: var(--text-muted); letter-spacing: 0.1em; }

    .event-info { flex: 1; min-width: 0; }
    .event-name {
        font-family: var(--font-heading);
        font-size: 1.1rem;
        color: var(--text);
        margin: 0 0 0.25rem;
    }
    .event-location { font-family: var(--font-body); color: var(--text-muted); font-size: 0.85rem; margin: 0 0 0.4rem; }
    .event-meta { display: flex; gap: 1rem; }
    .event-time, .event-attendees {
        font-family: var(--font-body); font-size: 0.8rem; color: var(--text-muted);
    }

    .event-going-badge {
        position: absolute; top: 1rem; right: 1rem;
        background: rgba(52,199,89,0.12);
        border: 1px solid rgba(52,199,89,0.3);
        color: #34c759;
        border-radius: 20px;
        padding: 0.2rem 0.7rem;
        font-family: var(--font-body);
        font-size: 0.75rem;
        font-weight: 600;
    }

    /* Modal */
    .modal-backdrop {
        position: fixed; inset: 0;
        background: rgba(0,0,0,0.6);
        display: flex; align-items: center; justify-content: center;
        z-index: 1000;
    }
    .modal-panel {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 12px;
        width: min(600px, 95vw);
        max-height: 90vh;
        overflow-y: auto;
    }
    .modal-header {
        display: flex; align-items: center; justify-content: space-between;
        padding: 1.25rem 1.75rem;
        border-bottom: 1px solid var(--border);
    }
    .modal-header h2 { font-family: var(--font-heading); font-size: 1.1rem; color: var(--text); margin: 0; }
    .modal-close { background: none; border: none; color: var(--text-muted); font-size: 1.4rem; cursor: pointer; }
    .modal-body { padding: 1.5rem 1.75rem; display: flex; flex-direction: column; gap: 1rem; }
    .modal-footer {
        display: flex; justify-content: flex-end; gap: 0.75rem;
        padding: 1rem 1.75rem 1.5rem;
        border-top: 1px solid var(--border);
    }

    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .btn-secondary {
        padding: 0.6rem 1.2rem;
        background: rgba(255,255,255,0.06);
        border: 1px solid var(--border);
        color: var(--text-muted);
        border-radius: 6px;
        font-family: var(--font-body);
        cursor: pointer;
    }
    .btn-gold {
        padding: 0.6rem 1.5rem;
        background: linear-gradient(135deg, #c9a84c, #a8883c);
        color: #07090f;
        border: none;
        border-radius: 6px;
        font-family: var(--font-heading);
        font-size: 0.85rem;
        font-weight: 700;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        cursor: pointer;
    }
    .btn-gold:disabled { opacity: 0.55; cursor: not-allowed; }

    .announcement-toggle {
        padding: 0.75rem 1rem;
        background: rgba(201,168,76,0.05);
        border: 1px solid rgba(201,168,76,0.15);
        border-radius: 8px;
    }
    .checkbox-label {
        display: flex; align-items: center; gap: 0.65rem;
        font-family: var(--font-body); font-size: 0.88rem; color: var(--text-muted);
        cursor: pointer; user-select: none;
    }
    .checkbox-label input[type="checkbox"] { accent-color: var(--gold); width: 15px; height: 15px; cursor: pointer; }
    .checkbox-label span { transition: color 0.15s; }
    .checkbox-label:hover span { color: var(--text); }
    .announcement-fields {
        display: flex; flex-direction: column; gap: 1rem;
        padding: 1rem;
        background: rgba(201,168,76,0.04);
        border: 1px solid rgba(201,168,76,0.12);
        border-radius: 8px;
    }

    @@media (max-width: 600px) {
        .form-grid { grid-template-columns: 1fr; }
    }
</style>

@code {
    private List<EventDto> _events = new();
    private bool _loading = true;
    private bool _canCreate;
    private string? _error;

    private bool _showCreateModal;
    private bool _saving;
    private string? _formError;
    private CreateEventRequest _form = new() { StartsAt = DateTime.Now.AddDays(1), EndsAt = DateTime.Now.AddDays(1).AddHours(2) };

    private bool _createAnnouncement;
    private CreateAnnouncementRequest _annForm = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        if (!await AuthService.IsAuthenticatedAsync())
        {
            Navigation.NavigateTo("/login");
            return;
        }

        _canCreate = await AuthService.HasPermissionAsync(Domain.Shared.Claims.Permissions.Events.Create);
        await LoadEvents();
        StateHasChanged();
    }

    private async Task LoadEvents()
    {
        _loading = true;
        var result = await EventService.GetAllAsync();
        _loading = false;

        if (result.IsSuccess) _events = result.Value;
        else _error = result.Error.Message;
    }

    private void ShowCreateModal()
    {
        _form = new CreateEventRequest { StartsAt = DateTime.Now.AddDays(1), EndsAt = DateTime.Now.AddDays(1).AddHours(2) };
        _annForm = new CreateAnnouncementRequest();
        _createAnnouncement = false;
        _formError = null;
        _showCreateModal = true;
    }

    private void GoToEvent(int id) => Navigation.NavigateTo("/events/" + id);

    private void CloseModal() => _showCreateModal = false;

    private async Task CreateEvent()
    {
        _formError = null;
        _saving = true;
        var result = await EventService.CreateAsync(_form);

        if (result.IsSuccess && _createAnnouncement)
        {
            _annForm.LinkedEventId = result.Value.Id;
            await AnnouncementService.CreateAsync(_annForm);
        }

        _saving = false;

        if (result.IsSuccess)
        {
            _showCreateModal = false;
            Navigation.NavigateTo("/events/" + result.Value.Id);
        }
        else
        {
            _formError = result.Error.Message;
        }
    }
}
