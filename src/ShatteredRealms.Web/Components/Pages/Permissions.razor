@page "/permissions"
@using ShatteredRealms.Application.DTOs.Permissions
@using ShatteredRealms.Web.Services
@inject PermissionService PermissionService
@inject AuthService AuthService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Permissions — ShatteredRealms</PageTitle>

<div class="perms-page">
    <div class="page-header">
        <h1>Permissions</h1>
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    @if (permissions == null)
    {
        <div class="perms-loading">
            <div class="loading-orb"></div>
            <span>Loading permissions…</span>
        </div>
    }
    else if (!permissions.Any())
    {
        <div class="alert alert-info">No permissions found.</div>
    }
    else
    {
        <div class="perms-grid">
            @foreach (var category in permissions.GroupBy(p => p.Category).OrderBy(g => g.Key))
            {
                <div class="perms-card">
                    <div class="perms-card-header">@category.Key</div>
                    <div class="perms-card-body">
                        @foreach (var permission in category)
                        {
                            <div class="perm-row">
                                <code class="perm-name">@permission.Name</code>
                                <span class="perm-desc">@permission.Description</span>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .perms-page { padding-bottom: 4rem; }

    .perms-loading {
        display: flex; align-items: center; gap: 1rem;
        justify-content: center; padding: 4rem;
        color: var(--text-muted); font-family: var(--font-body, 'Crimson Pro', Georgia, serif);
    }
    .loading-orb {
        width: 22px; height: 22px;
        border: 2px solid rgba(201,168,76,0.2);
        border-top-color: var(--gold);
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
    }
    @@keyframes spin { to { transform: rotate(360deg); } }

    .perms-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(min(100%, 320px), 1fr));
        gap: 1.25rem;
        align-items: start;
    }

    .perms-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 10px;
        overflow: hidden;
        transition: border-color 0.15s;
    }
    .perms-card:hover { border-color: rgba(201,168,76,0.25); }

    .perms-card-header {
        padding: 0.85rem 1.25rem;
        background: rgba(255,255,255,0.03);
        border-bottom: 1px solid var(--border);
        font-family: 'Cinzel', serif;
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--gold);
    }

    .perms-card-body {
        padding: 0.5rem 0;
    }

    .perm-row {
        display: flex;
        flex-direction: column;
        gap: 0.15rem;
        padding: 0.65rem 1.25rem;
        border-bottom: 1px solid rgba(255,255,255,0.03);
    }
    .perm-row:last-child { border-bottom: none; }

    .perm-name {
        font-family: 'Courier New', monospace;
        font-size: 0.78rem;
        color: var(--gold);
        background: rgba(201,168,76,0.08);
        border: 1px solid rgba(201,168,76,0.15);
        border-radius: 4px;
        padding: 0.1rem 0.45rem;
        display: inline-block;
        word-break: break-all;
    }

    .perm-desc {
        font-family: 'Crimson Pro', Georgia, serif;
        font-size: 0.85rem;
        color: var(--text-muted);
        line-height: 1.4;
    }
</style>

@code {
    private List<PermissionDto>? permissions;
    private string? errorMessage;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        if (!await AuthService.IsAuthenticatedAsync())
        {
            Navigation.NavigateTo("/login");
            return;
        }

        await LoadPermissions();
        StateHasChanged();
    }

    private async Task LoadPermissions()
    {
        try
        {
            permissions = await PermissionService.GetAllPermissionsAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }
}
