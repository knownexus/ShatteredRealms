@page "/register"
@using ShatteredRealms.Application.DTOs.Auth
@using ShatteredRealms.Web.Services
@inject AuthService AuthService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Register - ShatteredRealms</PageTitle>

<div class="login-container">
    <div class="login-card">
        <div class="card">
            <div class="card-body p-5">

                @if (_registered)
                {
                    <div class="text-center">
                        <div class="confirm-icon" aria-hidden="true">
                            <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <circle cx="24" cy="24" r="22" stroke="#c9a84c" stroke-width="1.5" opacity="0.5"/>
                                <path d="M14 24l7 7 13-14" stroke="#c9a84c" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </div>
                        <h2 class="mt-3 mb-2">Check your email</h2>
                        <p class="text-muted mb-4">
                            We sent a confirmation link to <strong style="color:var(--gold)">@_registeredEmail</strong>.
                            Click it to activate your account.
                        </p>
                        <a href="/login" class="btn btn-primary">Back to Sign In</a>
                    </div>
                }
                else
                {
                    <div class="text-center mb-4">
                        <span class="login-brand">ShatteredRealms</span>
                        <p class="login-subtitle">Create your account</p>
                    </div>

                    @if (!string.IsNullOrEmpty(_errorMessage))
                    {
                        <div class="alert alert-danger mb-4">@_errorMessage</div>
                    }

                    <div class="reg-row mb-3">
                        <div class="reg-col">
                            <label class="form-label">First Name</label>
                            <input @bind="_firstName" class="form-control" placeholder="Aiden" />
                        </div>
                        <div class="reg-col">
                            <label class="form-label">Last Name</label>
                            <input @bind="_lastName" class="form-control" placeholder="Vale" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Email Address</label>
                        <input @bind="_email" type="email" class="form-control" placeholder="you@example.com" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Password</label>
                        <input @bind="_password" type="password" class="form-control" placeholder="Min. 8 characters" />
                    </div>

                    <div class="mb-4">
                        <label class="form-label">Confirm Password</label>
                        <input @bind="_confirmPassword" type="password" class="form-control" placeholder="Repeat password" />
                    </div>

                    <button class="btn btn-primary btn-lg w-100 mb-3"
                            @onclick="HandleRegister"
                            disabled="@_isLoading">
                        @if (_isLoading)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                            <span>Creating account...</span>
                        }
                        else
                        {
                            <span>Create Account</span>
                        }
                    </button>

                    <p class="text-center text-muted" style="font-size:0.9rem;">
                        Already have an account? <a href="/login">Sign in</a>
                    </p>
                }
            </div>
        </div>
    </div>
</div>

<style>
    .confirm-icon {
        width: 56px;
        height: 56px;
        margin: 0 auto 0.5rem;
    }
    .confirm-icon svg { width: 100%; height: 100%; }

    .reg-row { display: flex; gap: 0.75rem; }
    .reg-col  { flex: 1; }
    @@media (max-width: 480px) { .reg-row { flex-direction: column; gap: 0; } }
</style>

@code {
    private string _firstName       = string.Empty;
    private string _lastName        = string.Empty;
    private string _email           = string.Empty;
    private string _password        = string.Empty;
    private string _confirmPassword = string.Empty;
    private string? _errorMessage;
    private bool _isLoading;
    private bool _registered;
    private string _registeredEmail = string.Empty;

    private async Task HandleRegister()
    {
        _errorMessage = null;

        if (string.IsNullOrWhiteSpace(_firstName) || string.IsNullOrWhiteSpace(_lastName))
        {
            _errorMessage = "Please enter your first and last name.";
            return;
        }

        if (string.IsNullOrWhiteSpace(_email))
        {
            _errorMessage = "Please enter your email address.";
            return;
        }

        if (_password != _confirmPassword)
        {
            _errorMessage = "Passwords do not match.";
            return;
        }

        if (_password.Length < 8)
        {
            _errorMessage = "Password must be at least 8 characters.";
            return;
        }

        try
        {
            _isLoading = true;

            var request = new RegisterRequest
            {
                Email     = _email.Trim(),
                Password  = _password,
                FirstName = _firstName.Trim(),
                LastName  = _lastName.Trim(),
            };

            var (success, requiresEmailConfirmation, _, errorMessage) = await AuthService.RegisterAsync(request);

            if (success)
            {
                if (requiresEmailConfirmation)
                {
                    _registeredEmail = _email.Trim();
                    _registered = true;
                }
                else
                {
                    Navigation.NavigateTo("/login?registered=1");
                }
            }
            else
            {
                _errorMessage = errorMessage ?? "Registration failed. Please try again.";
            }
        }
        catch
        {
            _errorMessage = "Could not connect to the server. Please try again.";
        }
        finally
        {
            _isLoading = false;
        }
    }
}
