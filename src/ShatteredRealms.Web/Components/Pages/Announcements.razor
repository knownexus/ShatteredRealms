@page "/announcements"
@using ShatteredRealms.Application.DTOs.Announcements
@using ShatteredRealms.Application.DTOs.Events
@using ShatteredRealms.Web.Services
@inject AnnouncementClientService AnnouncementService
@inject EventClientService EventService
@inject AuthService AuthService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Announcements — ShatteredRealms</PageTitle>

<div class="announcements-page">
    <div class="announcements-header">
        <div>
            <h1 class="announcements-title">Announcements</h1>
            <p class="announcements-subtitle">News and updates from the community</p>
        </div>
        @if (_canCreate)
        {
            <button class="btn-gold-outline" @onclick="ShowCreateModal">+ New Announcement</button>
        }
    </div>

    @if (!string.IsNullOrEmpty(_error))
    {
        <div class="alert alert-danger">@_error</div>
    }

    @if (_loading)
    {
        <div class="announcements-loading">
            <div class="loading-orb"></div>
            <span>Loading announcements…</span>
        </div>
    }
    else if (_announcements.Count == 0)
    {
        <div class="announcements-empty">
            <p>No announcements yet. Check back soon.</p>
        </div>
    }
    else
    {
        <div class="announcements-list">
            @foreach (var a in _announcements)
            {
                <article class="announcement-card" @onclick="() => GoToAnnouncement(a.Id)">
                    <div class="announcement-card-inner">
                        <div class="announcement-date-col">
                            <span class="ann-day">@a.CreatedAt.ToString("dd")</span>
                            <span class="ann-month">@a.CreatedAt.ToString("MMM").ToUpper()</span>
                            <span class="ann-year">@a.CreatedAt.ToString("yyyy")</span>
                        </div>
                        <div class="announcement-content">
                            <h2 class="announcement-title">@a.Title</h2>
                            <p class="announcement-excerpt">@Truncate(a.Body, 200)</p>
                            <div class="announcement-footer">
                                <span class="ann-author">by @a.AuthorName</span>
                                @if (a.LinkedEventId.HasValue && !string.IsNullOrEmpty(a.LinkedEventTitle))
                                {
                                    <button class="ann-event-link" @onclick:stopPropagation
                                            @onclick="() => GoToEvent(a.LinkedEventId!.Value)">
                                        📅 @a.LinkedEventTitle
                                    </button>
                                }
                                @if (a.UpdatedAt.HasValue)
                                {
                                    <span class="ann-updated">Updated @a.UpdatedAt.Value.ToString("MMM d")</span>
                                }
                            </div>
                        </div>
                        <div class="announcement-arrow">›</div>
                    </div>
                </article>
            }
        </div>
    }
</div>

@if (_showCreateModal)
{
    <div class="modal-backdrop" @onmousedown="() => _backdropDown = true" @onclick="CloseModalViaBackdrop">
        <div class="modal-panel" @onmousedown:stopPropagation @onclick:stopPropagation>
            <div class="modal-header">
                <h2>New Announcement</h2>
                <button class="modal-close" @onclick="CloseModal">×</button>
            </div>
            <div class="modal-body">
                @if (!string.IsNullOrEmpty(_formError))
                {
                    <div class="alert alert-danger">@_formError</div>
                }
                <div class="form-group">
                    <label class="form-label">Title</label>
                    <input class="form-control" @bind="_form.Title" placeholder="Announcement title" />
                </div>
                <div class="form-group">
                    <label class="form-label">Body</label>
                    <textarea class="form-control" rows="6" @bind="_form.Body" placeholder="Write your announcement…"></textarea>
                </div>
                <div class="form-group">
                    <label class="form-label">Linked Event (optional)</label>
                    <select class="form-control" @bind="_linkedEventStr">
                        <option value="">— No linked event —</option>
                        @foreach (var ev in _allEvents)
                        {
                            <option value="@ev.Id">@ev.Title (@ev.StartsAt.ToString("MMM d, yyyy"))</option>
                        }
                    </select>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-secondary" @onclick="CloseModal">Cancel</button>
                <button class="btn-gold" @onclick="CreateAnnouncement" disabled="@_saving">
                    @(_saving ? "Publishing…" : "Publish")
                </button>
            </div>
        </div>
    </div>
}

<style>
    .announcements-page { max-width: 900px; margin: 0 auto; padding: 2rem 1rem 4rem; }

    .announcements-header {
        display: flex; align-items: flex-end; justify-content: space-between;
        margin-bottom: 2rem; flex-wrap: wrap; gap: 1rem;
    }
    .announcements-title { font-family: var(--font-heading); font-size: 2rem; color: var(--gold); margin: 0 0 0.25rem; }
    .announcements-subtitle { font-family: var(--font-body); color: var(--text-muted); margin: 0; font-size: 0.95rem; }

    .btn-gold-outline {
        padding: 0.55rem 1.3rem; border: 1px solid var(--gold);
        background: transparent; color: var(--gold); border-radius: 6px;
        font-family: var(--font-heading); font-size: 0.82rem; font-weight: 700;
        letter-spacing: 0.06em; cursor: pointer; transition: background 0.15s, color 0.15s;
    }
    .btn-gold-outline:hover { background: var(--gold); color: #07090f; }

    .alert { padding: 0.75rem 1rem; border-radius: 6px; font-family: var(--font-body); font-size: 0.88rem; margin-bottom: 1rem; }
    .alert-danger { background: rgba(255,69,58,0.12); border: 1px solid rgba(255,69,58,0.3); color: #ff453a; }

    .announcements-loading {
        display: flex; align-items: center; gap: 1rem;
        justify-content: center; padding: 4rem;
        color: var(--text-muted); font-family: var(--font-body);
    }
    .loading-orb {
        width: 22px; height: 22px;
        border: 2px solid rgba(201,168,76,0.2);
        border-top-color: var(--gold);
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
    }
    @@keyframes spin { to { transform: rotate(360deg); } }

    .announcements-empty {
        text-align: center; padding: 4rem;
        color: var(--text-muted); font-family: var(--font-body);
    }

    .announcements-list { display: flex; flex-direction: column; gap: 1px; }

    .announcement-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 10px;
        cursor: pointer;
        transition: border-color 0.15s, transform 0.1s;
        margin-bottom: 0.75rem;
    }
    .announcement-card:hover { border-color: rgba(201,168,76,0.4); transform: translateY(-1px); }

    .announcement-card-inner {
        display: flex; align-items: stretch; gap: 0;
    }

    .announcement-date-col {
        display: flex; flex-direction: column; align-items: center; justify-content: center;
        min-width: 72px; padding: 1.25rem 0.75rem;
        border-right: 1px solid var(--border);
        background: rgba(201,168,76,0.04);
        border-radius: 10px 0 0 10px;
    }
    .ann-day { font-family: var(--font-heading); font-size: 1.6rem; color: var(--gold); line-height: 1; }
    .ann-month { font-family: var(--font-body); font-size: 0.68rem; color: var(--text-muted); letter-spacing: 0.1em; margin-top: 2px; }
    .ann-year { font-family: var(--font-body); font-size: 0.65rem; color: rgba(255,255,255,0.2); }

    .announcement-content { flex: 1; padding: 1.25rem 1.5rem; min-width: 0; }
    .announcement-title {
        font-family: var(--font-heading); font-size: 1.1rem;
        color: var(--text); margin: 0 0 0.5rem;
    }
    .announcement-excerpt {
        font-family: var(--font-body); font-size: 0.88rem;
        color: var(--text-muted); margin: 0 0 0.75rem;
        line-height: 1.5;
        display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
    }
    .announcement-footer {
        display: flex; align-items: center; gap: 1rem; flex-wrap: wrap;
        font-family: var(--font-body); font-size: 0.78rem; color: var(--text-muted);
    }
    .ann-author { }
    .ann-event-link {
        background: rgba(201,168,76,0.1); border: 1px solid rgba(201,168,76,0.25);
        color: var(--gold); border-radius: 4px; padding: 0.15rem 0.6rem;
        font-family: var(--font-body); font-size: 0.75rem; cursor: pointer;
        transition: background 0.15s;
    }
    .ann-event-link:hover { background: rgba(201,168,76,0.2); }
    .ann-updated { font-style: italic; }

    .announcement-arrow {
        display: flex; align-items: center; padding: 0 1.25rem;
        font-size: 1.4rem; color: var(--border);
        transition: color 0.15s;
    }
    .announcement-card:hover .announcement-arrow { color: var(--gold); }

    /* Modal */
    .modal-backdrop {
        position: fixed; inset: 0; background: rgba(0,0,0,0.6);
        display: flex; align-items: center; justify-content: center; z-index: 1000;
    }
    .modal-panel {
        background: var(--surface); border: 1px solid var(--border);
        border-radius: 12px; width: min(600px, 95vw); max-height: 90vh; overflow-y: auto;
    }
    .modal-header {
        display: flex; align-items: center; justify-content: space-between;
        padding: 1.25rem 1.75rem; border-bottom: 1px solid var(--border);
    }
    .modal-header h2 { font-family: var(--font-heading); font-size: 1.1rem; color: var(--text); margin: 0; }
    .modal-close { background: none; border: none; color: var(--text-muted); font-size: 1.4rem; cursor: pointer; }
    .modal-body { padding: 1.5rem 1.75rem; display: flex; flex-direction: column; gap: 1rem; }
    .modal-footer {
        display: flex; justify-content: flex-end; gap: 0.75rem;
        padding: 1rem 1.75rem 1.5rem; border-top: 1px solid var(--border);
    }

    .form-group { display: flex; flex-direction: column; gap: 0.4rem; }
    .form-label { font-family: var(--font-body); font-size: 0.82rem; color: var(--text-muted); letter-spacing: 0.04em; }
    .form-control {
        background: rgba(255,255,255,0.04); border: 1px solid var(--border);
        color: var(--text); border-radius: 6px; padding: 0.55rem 0.8rem;
        font-family: var(--font-body); font-size: 0.9rem; transition: border-color 0.15s;
    }
    .form-control:focus { outline: none; border-color: rgba(201,168,76,0.5); }

    .btn-secondary {
        padding: 0.6rem 1.2rem; background: rgba(255,255,255,0.06);
        border: 1px solid var(--border); color: var(--text-muted);
        border-radius: 6px; font-family: var(--font-body); cursor: pointer;
    }
    .btn-gold {
        padding: 0.6rem 1.5rem;
        background: linear-gradient(135deg, #c9a84c, #a8883c);
        color: #07090f; border: none; border-radius: 6px;
        font-family: var(--font-heading); font-size: 0.85rem;
        font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; cursor: pointer;
    }
    .btn-gold:disabled { opacity: 0.55; cursor: not-allowed; }
</style>

@code {
    private List<AnnouncementDto> _announcements = new();
    private bool _loading = true;
    private bool _canCreate;
    private string? _error;

    private bool _showCreateModal;
    private bool _saving;
    private string? _formError;
    private CreateAnnouncementRequest _form = new();
    private bool _backdropDown;
    private List<EventDto> _allEvents = new();
    private string _linkedEventStr = "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        if (!await AuthService.IsAuthenticatedAsync())
        {
            Navigation.NavigateTo("/login");
            return;
        }

        _canCreate = await AuthService.HasPermissionAsync(Domain.Shared.Claims.Permissions.Announcements.Create);
        await LoadAnnouncements();
        StateHasChanged();
    }

    private async Task LoadAnnouncements()
    {
        _loading = true;
        var result = await AnnouncementService.GetAllAsync();
        _loading = false;

        if (result.IsSuccess) _announcements = result.Value;
        else _error = result.Error.Message;
    }

    private void GoToAnnouncement(int id) => Navigation.NavigateTo("/announcements/" + id);
    private void GoToEvent(int id) => Navigation.NavigateTo("/events/" + id);

    private async Task ShowCreateModal()
    {
        _form = new CreateAnnouncementRequest();
        _linkedEventStr = "";
        _formError = null;

        var eventsResult = await EventService.GetAllAsync(upcomingOnly: false);
        _allEvents = eventsResult.IsSuccess ? eventsResult.Value : [];

        _showCreateModal = true;
        StateHasChanged();
    }

    private void CloseModal() => _showCreateModal = false;
    private void CloseModalViaBackdrop() { if (_backdropDown) CloseModal(); _backdropDown = false; }

    private async Task CreateAnnouncement()
    {
        _form.LinkedEventId = string.IsNullOrEmpty(_linkedEventStr) ? null : int.Parse(_linkedEventStr);
        _formError = null;
        _saving = true;
        var result = await AnnouncementService.CreateAsync(_form);
        _saving = false;

        if (result.IsSuccess)
        {
            _showCreateModal = false;
            Navigation.NavigateTo("/announcements/" + result.Value.Id);
        }
        else
        {
            _formError = result.Error.Message;
        }
    }

    private static string Truncate(string text, int maxLength)
        => text.Length <= maxLength ? text : text[..maxLength] + "…";
}
