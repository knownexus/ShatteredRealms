@using ShatteredRealms.Domain.Shared
@using ShatteredRealms.Web.Services
@inject AuthService AuthService
@inject AuthStateService AuthStateService
@inject NavigationManager Navigation
@implements IDisposable

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">ShatteredRealms</a>
    </div>
</div>

<div class="nav-scrollable">
    <nav class="nav flex-column">

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu"></span> Home
            </NavLink>
        </div>

        @if (_isAuthenticated)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="/forum">
                    <span class="bi bi-chat-left-text-fill me-2"></span>Forum
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="/wiki">
                    <span class="bi bi-journal-text me-2"></span>Wiki
                </NavLink>
            </div>

            @if (_isAdmin)
            {
                <div class="nav-item px-3">
                    <a class="nav-link" href="/users">Admin</a>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/users">
                        <span class="bi bi-journal-text me-2"></span>Users
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/roles">
                        <span class="bi bi-journal-text me-2"></span>Roles
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/permissions">
                        <span class="bi bi-journal-text me-2"></span>RoleClaims
                    </NavLink>
                </div>
            }

            <div class="nav-item px-3 mt-2">
                <button class="nav-link btn btn-link text-danger" type="button" @onclick="Logout">
                    Logout
                </button>
            </div>
        }
        else
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="/login">Login</NavLink>
            </div>
        }

    </nav>
</div>

@code {
    private bool _isAuthenticated;
    private bool _isAdmin;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        // localStorage is only available after the circuit is up - must be OnAfterRenderAsync
        AuthStateService.OnAuthStateChanged += HandleAuthStateChanged;
        await RefreshAuthState();
        StateHasChanged();
    }

    private async Task RefreshAuthState()
    {
        _isAuthenticated = await AuthService.IsAuthenticatedAsync();
        // Use a permission that only admins/system accounts have
        _isAdmin = _isAuthenticated && await AuthService.HasPermissionAsync(Claims.Permissions.Users.View);
    }

    private async Task HandleAuthStateChanged()
    {
        await RefreshAuthState();
        await InvokeAsync(StateHasChanged);
    }

    private async Task Logout()
    {
        await AuthService.LogoutAsync();
        _isAuthenticated = false;
        _isAdmin = false;
        StateHasChanged();
        Navigation.NavigateTo("/login");
    }

    public void Dispose()
    {
        AuthStateService.OnAuthStateChanged -= HandleAuthStateChanged;
    }
}
